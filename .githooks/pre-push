#!/usr/bin/env bash
# Pre-push hook: run the same checks CI runs (lint + typecheck) so
# stylistic / type regressions don't waste a CI cycle.
#
# Skip with `git push --no-verify` if you genuinely need to.

set -e

# Resolve repo root regardless of where the hook fires from.
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

echo "[pre-push] biome check ."
bun run lint

echo "[pre-push] turbo run typecheck"
bun run typecheck

echo "[pre-push] ok"
