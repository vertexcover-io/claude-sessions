{
  "name": "claude-sessions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "db:migrate": "turbo run db:migrate",
    "stack:up": "podman compose up -d --build",
    "stack:down": "podman compose down",
    "stack:logs": "podman compose logs -f api",
    "stack:rebuild": "podman compose build api && podman compose up -d",
    "stack:dev": "CLAUDE_SESSIONS_DEV=1 podman compose up -d --build",
    "watch": "turbo run watch --parallel",
    "cs": "node packages/cli/dist/main.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.2.19"
}
